# ===== Server =====
PORT=5000
NODE_ENV=development

# ===== MongoDB =====
# Local: mongodb://127.0.0.1:27017/hostel_food
# Atlas: mongodb+srv://<user>:<pass>@cluster0.mongodb.net/hostel_food
MONGO_URI=mongodb://127.0.0.1:27017/hostel_food

# ===== Fast2SMS =====
# Get yours at https://www.fast2sms.com (never commit the real key)
FAST2SMS_API_KEY=your_fast2sms_api_key_here
# Comma-separated 10-digit numbers, no +91 prefix
ALERT_RECIPIENTS=9999999999,8888888888

# ===== Alert thresholds =====
RATING_THRESHOLD=3.0
MIN_STUDENTS_THRESHOLD=30

# ===== CORS =====
CLIENT_ORIGIN=http://localhost:5173
